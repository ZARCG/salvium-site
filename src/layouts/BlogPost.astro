---
// Layout for individual blog posts. Wraps the markdown body in a prose
// container, prefixes a hero with title/category/date, and reuses the site
// chrome via the base Layout.
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { href } from '../lib/href';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category: string;
  image?: string;
}

const { title, description, date, category, image } = Astro.props;
---

<Layout title={title} description={description} ogImage={image} article>
  <article class="max-w-4xl mx-auto px-5 lg:px-8 py-16 md:py-24">
    <a href={href('/blog')} class="text-sm text-[color:var(--color-teal)] hover:text-white transition-colors inline-flex items-center gap-1 mb-8">
      ← All posts
    </a>

    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-3 text-xs font-mono uppercase tracking-[0.18em] text-[color:var(--color-text-muted)] mb-5">
        <span class="text-[color:var(--color-teal)]">{category}</span>
        <span>·</span>
        <FormattedDate date={date} />
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight tracking-tight">
        {title}
      </h1>
      {description && (
        <p class="mt-5 text-lg text-[color:var(--color-text-muted)] leading-relaxed">
          {description}
        </p>
      )}
    </header>

    {image && (
      <img
        src={image}
        alt={title}
        class="w-full rounded-xl border border-[color:var(--color-border)] mb-12"
        loading="eager"
        onerror="this.style.display='none'"
      />
    )}

    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>
