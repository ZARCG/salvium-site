---
const SOCIALS = [
  { name: 'X (Twitter)', href: 'https://x.com/salvium_io' },
  { name: 'Telegram',    href: 'https://t.me/salviumcommunity' },
  { name: 'Discord',     href: 'https://discord.com/invite/P3rrAjkyYs' },
  { name: 'GitHub',      href: 'https://github.com/salvium' },
  { name: 'Reddit',      href: 'https://www.reddit.com/user/Salvium_Project/' },
];
---

<section id="community" class="section-chapter relative py-20 md:py-36">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="feature-card px-5 sm:px-10 py-14 sm:py-20 md:py-28 text-center">
      <div class="relative max-w-3xl mx-auto">
        <div class="font-mono text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
          / Community
        </div>
        <h2 class="chapter-title mt-5">
          Join the <span class="neon-text">network</span>.
        </h2>
        <p class="mt-6 text-white/75 text-lg leading-relaxed">
          Builders, miners, holders, and the curious — gather where the
          conversation actually happens.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          {SOCIALS.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              {s.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
