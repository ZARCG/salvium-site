---
import { STATS } from '../../data/seed.js';
---

<section class="section-chapter relative py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-y-8">
      {STATS.map((s) => (
        <div class="text-center md:text-left">
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">
            {s.label}
          </div>
          <div class="mt-2 font-display text-2xl md:text-3xl font-semibold tracking-tight text-white">
            {s.value}
          </div>
          <div class="mt-1 font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-teal)]">
            {s.suffix}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
