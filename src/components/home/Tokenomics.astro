---
// Tokenomics — supply distribution. Renders the three buckets with a
// horizontal stacked bar at the top showing relative percentages, then
// expanded cards underneath.
import { TOKENOMICS } from '../../data/seed.js';
---

<section class="section-chapter relative py-20 md:py-32">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="max-w-3xl">
      <div class="font-mono text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
        / Tokenomics
      </div>
      <h2 class="chapter-title mt-5">
        Capped supply.<br>
        <span class="neon-text">184.4M SAL</span>.
      </h2>
      <p class="mt-6 text-white/70 max-w-2xl text-lg leading-relaxed">
        Mining and staking distribute most of the supply. A small operations
        fund and an early-build fund cover the remainder.
      </p>
    </div>

    <!-- Stacked bar -->
    <div class="mt-12 flex h-3 rounded-full overflow-hidden border border-white/10">
      {TOKENOMICS.map((t) => (
        <div
          class="h-full"
          style={`flex: ${t.pct} 1 0; background-color: ${t.color};`}
          title={`${t.label}: ${t.pct}%`}
        />
      ))}
    </div>

    <div class="mt-10 grid md:grid-cols-3 gap-5">
      {TOKENOMICS.map((t) => (
        <div class="glass p-6">
          <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.22em] text-white/60">
            <span class="w-2 h-2 rounded-full" style={`background-color: ${t.color}`}></span>
            {t.pct}%
          </div>
          <h3 class="mt-3 font-display text-lg font-semibold text-white">{t.label}</h3>
          <p class="mt-3 text-sm text-white/65 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
