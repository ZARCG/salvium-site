---
// Tokenomics — two-column layout: copy + CTAs on the left, supply
// distribution card on the right. Direct port of App.jsx:1107-1190.
import Reveal from '../Reveal.astro';
import SectionEyebrow from '../SectionEyebrow.astro';
import { href } from '../../lib/href';
import { TOKENOMICS } from '../../data/seed.js';
---

<section id="tokenomics" class="section-chapter relative py-20 md:py-36">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <Reveal>
        <div>
          <SectionEyebrow num="04" label="Tokenomics" />
          <h2 class="chapter-title mt-6">
            Designed to reward participation.
          </h2>
          <p class="mt-4 text-white/70">
            Salvium&rsquo;s tokenomics reward active participation, fund ongoing innovation,
            and ensure long-term sustainability. Percentages refer to the capped
            184.4M SAL supply and exclude tail emissions, which continue beyond the
            cap to support long-term miner incentives.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-ghost text-sm py-2 px-4" href={href('/papers')}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Read the papers
            </a>
            <a class="btn-ghost text-sm py-2 px-4" href={href('/about')}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Full breakdown
            </a>
          </div>
        </div>
      </Reveal>

      <Reveal delay={120}>
        <div class="relative glass glow-border rounded-3xl p-5 sm:p-7 overflow-hidden">
          <!-- Faint coin watermark behind the distribution card. Decorative;
               onerror hides it cleanly if the asset is ever moved. -->
          <img
            src={href('/brand/coin_icon/white/circular/svg/salvium_coin_white_transparent.svg')}
            alt=""
            aria-hidden="true"
            class="absolute -right-16 -bottom-16 w-72 opacity-[0.06] pointer-events-none select-none"
            draggable="false"
            onerror="this.style.display='none'"
          />
          <div class="relative text-xs uppercase tracking-[0.18em] text-[color:var(--color-text-lighter)] mb-3">
            Capped supply distribution
          </div>
          <div class="h-3 w-full rounded-full overflow-hidden flex bg-white/5">
            {TOKENOMICS.map((t) => (
              <div class="h-full" style={`width: ${t.pct}%; background: ${t.color};`}></div>
            ))}
          </div>

          <div class="mt-6 grid gap-4">
            {TOKENOMICS.map((t) => (
              <div class="flex gap-4">
                <div class="mt-1 w-3 h-3 rounded shrink-0" style={`background: ${t.color};`}></div>
                <div class="flex-1">
                  <div class="flex items-baseline justify-between gap-3">
                    <div class="font-semibold text-white">{t.label}</div>
                    <div class="font-mono text-[color:var(--color-teal)]">{t.pct}%</div>
                  </div>
                  <p class="text-sm text-white/65 mt-1 leading-relaxed">{t.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-6 pt-5 border-t border-white/5 grid grid-cols-3 gap-3 sm:gap-4 text-sm">
            <div>
              <div class="text-[color:var(--color-text-lighter)] text-xs uppercase tracking-[0.18em]">Cap</div>
              <div class="font-mono text-white mt-1">184.4M SAL</div>
            </div>
            <div>
              <div class="text-[color:var(--color-text-lighter)] text-xs uppercase tracking-[0.18em]">Tail emission</div>
              <div class="font-mono text-white mt-1">Yes</div>
            </div>
            <div>
              <div class="text-[color:var(--color-text-lighter)] text-xs uppercase tracking-[0.18em]">Algo</div>
              <div class="font-mono text-white mt-1">RandomX</div>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
