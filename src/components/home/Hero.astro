---
// Salvium hero — direct port of siko-ctrl's React Hero. The standout visual
// is the animated "Private & Programmable = Sovereign" equation: each token
// drops in with a blur-clear animation, then "Sovereign" picks up a slow
// continuous teal glow. All CSS, no JS — works with prefers-reduced-motion.
//
// Aurora backdrop simplified vs the React version (no SVG noise filter,
// no parallax beams) to keep the page light. The radial gradient on body
// already provides the ambient teal glow; we add the cinematic vignette
// here scoped to the hero only.
import { href } from '../../lib/href';
import NodeNetwork from '../islands/NodeNetwork.tsx';
---

<section id="top" class="hero-section relative min-h-[100svh] flex items-center pt-24 pb-20 overflow-hidden">
  <!-- Backdrop: aurora beams + bloom orbs + vignette + grain -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0" style="background: radial-gradient(130% 100% at 50% 40%, #181818 0%, #0a0a0a 75%, #050505 100%);"></div>
    <div class="aurora-stage">
      <span class="beam beam-1"></span>
      <span class="beam beam-2"></span>
      <span class="beam beam-3"></span>
      <span class="beam beam-4"></span>
      <span class="beam beam-5"></span>
    </div>
    <!-- Animated node network. React island, hydrated only in the browser
         and only when the hero is in view (client:visible). The canvas
         scales to its container so it sits behind the hero content. -->
    <div class="absolute inset-0 opacity-60 mix-blend-screen pointer-events-none">
      <NodeNetwork client:visible />
    </div>
    <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(55% 60% at 50% 50%, rgba(0,0,0,0.55) 0%, transparent 75%);"></div>
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-transparent to-[#0a0a0a]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-5 lg:px-8 w-full text-center">
    <div class="text-[10px] sm:text-xs uppercase tracking-[0.4em] text-[color:var(--color-text-lighter)] font-mono">
      The Future of Private DeFi
    </div>

    <h1
      class="hero-equation mt-3 font-display font-semibold tracking-[-0.02em] leading-[0.95]"
      style="font-size: clamp(2rem, 7.5vw, 6rem);"
      aria-label="Private and Programmable equals Sovereign"
    >
      <span class="drop word"   style="--d: 0.40s">Private</span>
      <span class="drop op"     style="--d: 0.85s" aria-hidden="true">&amp;</span>
      <span class="drop word"   style="--d: 1.15s">Programmable</span>
      <span class="drop op"     style="--d: 1.75s" aria-hidden="true">=</span>
      <span class="drop word sovereign" style="--d: 2.05s">Sovereign</span>
    </h1>

    <p class="mt-6 max-w-xl mx-auto text-sm sm:text-base text-white/65 leading-relaxed">
      The industry&rsquo;s first Layer 1 PoW privacy blockchain that balances
      enhanced privacy, regulatory compatibility, and private DeFi.
    </p>

    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href={href('/about')} class="btn-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a class="btn-ghost" href="https://docs.salvium.io/" target="_blank" rel="noopener noreferrer">
        Read the Docs
      </a>
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-[10px] sm:text-xs uppercase tracking-[0.22em] text-[color:var(--color-text-lighter)] font-mono">
      <span class="flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-teal)]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        Privacy by Design
      </span>
      <span class="hidden sm:inline-block w-1 h-1 rounded-full bg-white/30"></span>
      <span class="flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-teal)]"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
        Regulatory Resilience
      </span>
      <span class="hidden sm:inline-block w-1 h-1 rounded-full bg-white/30"></span>
      <span class="flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-teal)]"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
        Privacy Meets Possibility
      </span>
    </div>
  </div>
</section>

<style>
  /* Hero-scoped styles. Only the .hero-equation animations are scoped to
     this section because they're part of the hero's identity; every other
     style is in global.css. */
  .hero-section .aurora-stage {
    position: absolute;
    inset: -10% -5%;
    filter: blur(40px) saturate(140%);
    will-change: transform, filter;
  }
  .hero-section .beam {
    position: absolute;
    top: -20%;
    height: 140%;
    border-radius: 50%;
    mix-blend-mode: screen;
    opacity: 0.85;
    transform-origin: 50% 50%;
    will-change: transform, opacity;
  }
  .hero-section .beam-1 {
    left: 6%; width: 10vw; max-width: 220px;
    background: linear-gradient(180deg, transparent 0%, rgba(64,224,208,0.55) 25%, rgba(0,191,165,0.85) 50%, rgba(10,235,133,0.55) 75%, transparent 100%);
    animation: beam-drift 18s ease-in-out infinite;
  }
  .hero-section .beam-2 {
    left: 22%; width: 7vw; max-width: 160px;
    background: linear-gradient(180deg, transparent 0%, rgba(128,203,196,0.5) 30%, rgba(64,224,208,0.75) 55%, rgba(0,191,165,0.45) 80%, transparent 100%);
    animation: beam-drift 22s ease-in-out -4s infinite;
  }
  .hero-section .beam-3 {
    left: 44%; width: 9vw; max-width: 200px;
    background: linear-gradient(180deg, transparent 0%, rgba(0,191,165,0.5) 30%, rgba(64,224,208,0.7) 55%, rgba(10,235,133,0.45) 80%, transparent 100%);
    animation: beam-drift 26s ease-in-out -10s infinite;
  }
  .hero-section .beam-4 {
    left: 65%; width: 8vw; max-width: 180px;
    background: linear-gradient(180deg, transparent 0%, rgba(64,224,208,0.5) 25%, rgba(0,191,165,0.75) 55%, rgba(10,235,133,0.45) 80%, transparent 100%);
    animation: beam-drift 20s ease-in-out -7s infinite;
  }
  .hero-section .beam-5 {
    left: 82%; width: 6vw; max-width: 140px;
    background: linear-gradient(180deg, transparent 0%, rgba(128,203,196,0.5) 30%, rgba(64,224,208,0.7) 55%, rgba(0,191,165,0.45) 80%, transparent 100%);
    animation: beam-drift 24s ease-in-out -2s infinite;
  }
  @keyframes beam-drift {
    0%,100% { transform: translateY(0) scaleY(1); opacity: 0.65; }
    50%     { transform: translateY(-3%) scaleY(1.03); opacity: 0.9; }
  }

  /* The animated equation. Each .drop falls in with a blur-clear + scale,
     timed by the inline --d variable so words land sequentially. */
  .hero-equation {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.2em 0.45em;
    line-height: 1.08;
    color: #fff;
  }
  .hero-equation .word { padding-bottom: 0.18em; }
  .hero-equation .drop {
    display: inline-block;
    opacity: 0;
    transform: translateY(-0.6em) scale(0.96);
    filter: blur(10px);
    animation: token-drop 0.8s cubic-bezier(0.2, 0.7, 0.15, 1.05) forwards;
    animation-delay: var(--d, 0s);
    will-change: transform, opacity, filter;
  }
  .hero-equation .op {
    color: #40E0D0;
    font-weight: 500;
    font-size: 0.82em;
    text-shadow: 0 0 24px rgba(64, 224, 208, 0.55);
    animation: token-pop 0.7s cubic-bezier(0.2, 0.9, 0.2, 1.1) forwards;
    animation-delay: var(--d, 0s);
  }
  .hero-equation .sovereign {
    background: linear-gradient(180deg, #ffffff 0%, #80cbc4 60%, #00BFA5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    position: relative;
    text-shadow: 0 0 0 rgba(0, 191, 165, 0);
    animation:
      token-drop 0.8s cubic-bezier(0.2, 0.7, 0.15, 1.05) forwards,
      sovereign-glow 3.6s ease-in-out 2.4s infinite;
    animation-delay: var(--d, 0s), 2.4s;
  }
  @keyframes token-drop {
    0%   { opacity: 0; transform: translateY(-0.7em) scale(0.94); filter: blur(12px); }
    60%  { opacity: 1; transform: translateY(0.08em) scale(1.02); filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }
  @keyframes token-pop {
    0%   { opacity: 0; transform: translateY(-0.4em) rotate(-15deg) scale(0.6); filter: blur(8px); }
    60%  { opacity: 1; transform: translateY(0) rotate(8deg) scale(1.15); filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) rotate(0) scale(1); filter: blur(0); }
  }
  @keyframes sovereign-glow {
    0%, 100% { text-shadow: 0 0 14px rgba(0,191,165,0.25), 0 0 30px rgba(64,224,208,0.10); }
    50%      { text-shadow: 0 0 28px rgba(0,191,165,0.55), 0 0 60px rgba(64,224,208,0.30); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-section .beam,
    .hero-equation .drop,
    .hero-equation .op,
    .hero-equation .sovereign {
      opacity: 1; transform: none; filter: none; animation: none;
    }
  }
</style>
