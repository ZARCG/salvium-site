---
// "Why Salvium" — three-up cards introducing the pillars. Direct port of
// siko-ctrl's React Why (App.jsx:903-959): each card has a leading icon,
// section index 0N, the title, and a copy-block. Heading reads "Privacy,
// regulatory compatibility, and smart contracts."
import Reveal from '../Reveal.astro';
import SectionEyebrow from '../SectionEyebrow.astro';

// Inline lucide paths so we don't pay the React-runtime cost on a static
// section. Same shapes siko-ctrl picked: Lock, Scale, Sparkles.
const CARDS = [
  {
    icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    title: 'Privacy by Design',
    body:
      'Built on robust cryptographic foundations with zero-knowledge proofs for uncompromising security and confidentiality. Stealth addresses, ring signatures, and RingCT inherited from Monero, extended with CARROT and SPARC.',
  },
  {
    icon: '<path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>',
    title: 'Regulatory Resilience',
    body:
      'One of the few privacy-focused chains striving for MiCA compliance, designed to thrive where others cannot operate. Refundable transactions, view keys, and spend authority proofs make Salvium exchange-ready.',
  },
  {
    icon: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>',
    title: 'Privacy Meets Possibility',
    body:
      'Developing private smart contract capabilities for DeFi, stablecoins, and more, all while preserving transaction confidentiality. Ethereum dApp porting middleware is on the roadmap.',
  },
];
---

<section id="why" class="section-chapter relative py-20 md:py-36">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <Reveal>
      <div class="max-w-3xl">
        <SectionEyebrow num="01" label="Why Salvium" />
        <h2 class="chapter-title mt-6">
          Privacy, regulatory compatibility,<br>and smart contracts.
        </h2>
        <p class="mt-4 text-white/70">
          The foundation of a truly sovereign financial future, built without
          compromise on either side of the regulatory line.
        </p>
      </div>
    </Reveal>

    <div class="mt-14 grid md:grid-cols-3 gap-4">
      {CARDS.map((c, i) => (
        <Reveal delay={i * 100}>
          <article class="s-card h-full pb-20">
            <div class="flex items-start justify-between">
              <div class="w-11 h-11 rounded-lg bg-white/[0.03] border border-white/10 text-[color:var(--color-teal)] flex items-center justify-center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
              </div>
              <span class="s-card-index">0{i + 1}</span>
            </div>
            <h3 class="mt-7 text-2xl font-display font-semibold text-white tracking-tight">{c.title}</h3>
            <p class="mt-3 text-white/65 leading-relaxed text-[0.95rem]">{c.body}</p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
