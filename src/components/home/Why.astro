---
import Reveal from '../Reveal.astro';
// "Why Salvium" three-column pitch — Privacy · Compliance · Programmable.
// Direct port of the React Why component, kept layout-equivalent so the
// page rhythm matches siko-ctrl's design.
const PILLARS = [
  {
    eyebrow: 'Privacy',
    title: 'Private by default',
    body: 'Stealth addresses, ring signatures, RingCT, and CARROT outputs hide sender, receiver, and amount on every transaction.',
  },
  {
    eyebrow: 'Compliance',
    title: 'Compliant when needed',
    body: 'Selective transparency via shareable view keys lets users prove what they need to, without leaking what they don’t.',
  },
  {
    eyebrow: 'Programmable',
    title: 'Smart by design',
    body: 'Protocol-level transaction primitives unlock private DeFi: stable assets, swaps, lending — without surrendering privacy.',
  },
];
---

<section class="section-chapter relative py-20 md:py-32">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <Reveal>
      <div class="max-w-3xl">
        <div class="font-mono text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
          / Why Salvium
        </div>
        <h2 class="chapter-title mt-5">
          Privacy, compliance,<br>
          and <span class="neon-text">smart contracts.</span>
        </h2>
        <p class="mt-6 text-white/70 max-w-2xl text-lg leading-relaxed">
          Three pillars form the foundation of a truly sovereign financial future.
        </p>
      </div>
    </Reveal>

    <div class="mt-14 grid md:grid-cols-3 gap-5">
      {PILLARS.map((p, i) => (
        <Reveal delay={i * 120}>
          <div class="s-card h-full">
            <div class="s-card-index">/ {p.eyebrow}</div>
            <h3 class="mt-4 font-display text-xl md:text-2xl font-semibold text-white">
              {p.title}
            </h3>
            <p class="mt-3 text-white/65 leading-relaxed">{p.body}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
