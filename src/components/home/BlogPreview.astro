---
// Latest 3 posts. Direct port of App.jsx:1337-1391:
//   - SectionEyebrow "06 / Blog" + "Field notes from the protocol." headline
//   - "View all posts" ghost button in header row
//   - 3-up cards on desktop, 2-up tablet, stacked mobile
//   - Each card: BlogCover + category + date + title + excerpt + read-time + arrow
//   - Bottom-centred btn-primary "Read the blog" CTA
import Reveal from '../Reveal.astro';
import SectionEyebrow from '../SectionEyebrow.astro';
import BlogCover from '../BlogCover.astro';
import FormattedDate from '../FormattedDate.astro';
import { getResolvedPosts } from '../../lib/posts';
import { href } from '../../lib/href';

const latest = (await getResolvedPosts()).slice(0, 3);
---

<section id="blog" class="section-chapter relative py-20 md:py-36">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <Reveal>
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div class="max-w-3xl">
          <SectionEyebrow num="06" label="Blog" />
          <h2 class="mt-6 font-display font-semibold tracking-[-0.02em] leading-[1.02] text-white"
              style="font-size: clamp(2.25rem, 6.5vw, 5.75rem);">
            Field notes from<br>the protocol.
          </h2>
          <p class="mt-4 text-white/70">
            Releases, cryptography, compliance, and updates from the Salvium team.
          </p>
        </div>
        <a href={href('/blog')} class="btn-ghost text-sm py-2 px-4">
          View all posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </Reveal>

    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {latest.map((p, i) => (
        <Reveal delay={i * 60}>
          <a href={p.href} class="s-card h-full pb-16 text-left flex flex-col w-full no-underline">
            <BlogCover category={p.category} title={p.entry.data.title} image={p.entry.data.image} />
            <div class="mt-5 flex items-center justify-between gap-3 text-[11px]">
              <span class="font-mono uppercase tracking-[0.18em] text-[color:var(--color-teal)]">
                {p.category}
              </span>
              <span class="flex items-center gap-1.5 font-mono text-[color:var(--color-text-lighter)]">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <FormattedDate date={p.date} />
              </span>
            </div>
            <h3 class="mt-3 text-lg font-display font-semibold text-white leading-snug tracking-tight">
              {p.entry.data.title}
            </h3>
            {p.entry.data.excerpt && (
              <p class="mt-3 text-sm text-white/60 leading-relaxed line-clamp-4">
                {p.entry.data.excerpt}
              </p>
            )}
            <div class="mt-auto pt-5 text-[11px] text-[color:var(--color-text-lighter)] flex items-center gap-1.5 font-mono">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {p.readingMinutes} min read
            </div>
            <span class="s-card-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        </Reveal>
      ))}
    </div>

    <Reveal delay={200}>
      <div class="mt-10 flex justify-center">
        <a href={href('/blog')} class="btn-primary">
          Read the blog
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </Reveal>
  </div>
</section>
