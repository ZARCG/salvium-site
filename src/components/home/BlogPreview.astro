---
import { getResolvedPosts } from '../../lib/posts';
import FormattedDate from '../FormattedDate.astro';
import { href } from '../../lib/href';

const latest = (await getResolvedPosts()).slice(0, 3);
---

<section id="blog" class="section-chapter relative py-20 md:py-32">
  <div class="max-w-7xl mx-auto px-5 lg:px-8">
    <div class="flex items-end justify-between gap-4 mb-12">
      <div>
        <div class="font-mono text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
          / Latest
        </div>
        <h2 class="chapter-title mt-5">
          From the <span class="neon-text">blog</span>.
        </h2>
      </div>
      <a href={href('/blog')} class="hidden md:inline-flex items-center gap-1 text-sm text-[color:var(--color-teal)] hover:text-white transition-colors">
        All posts →
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {latest.map((post) => (
        <a href={post.href} class="s-card h-full pb-16 text-left flex flex-col no-underline">
          <div class="flex items-center justify-between gap-3 text-[11px]">
            <span class="font-mono uppercase tracking-[0.18em] text-[color:var(--color-teal)]">
              {post.category}
            </span>
            <span class="flex items-center gap-1.5 font-mono text-white/40">
              <FormattedDate date={post.date} />
            </span>
          </div>
          <h3 class="mt-4 text-lg font-display font-semibold text-white leading-snug tracking-tight">
            {post.entry.data.title}
          </h3>
          {post.entry.data.excerpt && (
            <p class="mt-3 text-sm text-white/60 leading-relaxed line-clamp-3">
              {post.entry.data.excerpt}
            </p>
          )}
          <span class="s-card-arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center md:hidden">
      <a href={href('/blog')} class="btn-ghost">All posts</a>
    </div>
  </div>
</section>
