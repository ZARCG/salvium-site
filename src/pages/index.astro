---
// Salvium homepage. Phase 1: hero + a strip of latest posts + CTA. The full
// suite of home sections (Stats, Why, HowItWorks, Tokenomics, Roadmap,
// Products, Community) ports across in Phase 2 — kept the layout intentionally
// simple here so the deploy pipeline can be validated end-to-end.
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getResolvedPosts } from '../lib/posts';
import { href } from '../lib/href';

const latest = (await getResolvedPosts()).slice(0, 3);
---

<Layout>
  <!-- Hero -->
  <section class="relative pt-24 md:pt-36 pb-20 overflow-hidden">
    <div class="max-w-6xl mx-auto px-5 lg:px-8 text-center">
      <div class="font-mono text-xs uppercase tracking-[0.32em] text-[color:var(--color-teal)] mb-5">
        / Layer 1 · Privacy · Compliance · DeFi
      </div>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
        The Future of <span class="gradient-text">Private DeFi</span>
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl text-[color:var(--color-text-muted)]">
        A Layer 1 blockchain that balances enhanced privacy with regulatory
        compatibility, built for a sovereign programmable economy.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href={href('/about')} class="btn-primary">Get started</a>
        <a href="https://docs.salvium.io/" target="_blank" rel="noopener noreferrer" class="btn-ghost">
          Read the docs
        </a>
      </div>
      <ul class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-[color:var(--color-text-muted)] list-none p-0">
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-teal)]"></span> Private</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-teal)]"></span> Compliant</li>
        <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-teal)]"></span> Programmable</li>
      </ul>
    </div>
  </section>

  <!-- Latest posts strip -->
  <section class="py-20 border-t border-[color:var(--color-border)]">
    <div class="max-w-6xl mx-auto px-5 lg:px-8">
      <div class="flex items-end justify-between gap-4 mb-10">
        <div>
          <div class="font-mono text-xs uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
            / Latest
          </div>
          <h2 class="mt-3 text-2xl md:text-3xl font-bold tracking-tight">From the blog</h2>
        </div>
        <a href={href('/blog')} class="text-sm text-[color:var(--color-teal)] hover:text-white transition-colors">
          All posts →
        </a>
      </div>
      <ul class="grid md:grid-cols-3 gap-5 list-none p-0">
        {latest.map((post) => (
          <li>
            <a href={post.href} class="glass block h-full p-5 hover:border-[color:var(--color-teal)]/40 transition-colors">
              <div class="flex items-center gap-3 text-xs font-mono uppercase tracking-[0.18em] text-[color:var(--color-text-muted)] mb-3">
                <span class="text-[color:var(--color-teal)]">{post.category}</span>
                <span>·</span>
                <FormattedDate date={post.date} />
              </div>
              <h3 class="text-base font-semibold text-white leading-snug tracking-tight">
                {post.entry.data.title}
              </h3>
              {post.entry.data.excerpt && (
                <p class="mt-2 text-sm text-[color:var(--color-text-muted)] leading-relaxed line-clamp-3">
                  {post.entry.data.excerpt}
                </p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Phase-1 placeholder note. Remove once secondary sections are ported. -->
  <section class="py-12 border-t border-[color:var(--color-border)]">
    <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
      <p class="text-sm text-[color:var(--color-text-muted)]">
        This is a Phase 1 preview. Stats, tokenomics, roadmap, and product sections
        will be ported in subsequent commits.
      </p>
    </div>
  </section>
</Layout>
