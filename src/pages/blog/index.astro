---
// Blog index — lists every published post sorted newest-first. Cards link
// to the canonical /blog/<slug>/ URL. Search/filter UI can be added later
// as a React island; Phase 1 keeps it static.
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getResolvedPosts } from '../../lib/posts';

const posts = await getResolvedPosts();
---

<Layout
  title="Blog"
  description="Releases, cryptography, compliance, and field notes from the Salvium team."
>
  <section class="max-w-6xl mx-auto px-5 lg:px-8 py-16 md:py-24">
    <header class="max-w-2xl mb-14">
      <div class="font-mono text-xs uppercase tracking-[0.32em] text-[color:var(--color-teal)]">
        / Blog
      </div>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">
        Salvium <span class="gradient-text">Journal</span>
      </h1>
      <p class="mt-5 text-[color:var(--color-text-muted)] text-lg leading-relaxed">
        Releases, cryptography, compliance, and field notes from the Salvium team.
      </p>
    </header>

    <ul class="grid sm:grid-cols-2 gap-5 list-none p-0">
      {posts.map((post) => (
        <li>
          <a
            href={post.href}
            class="glass block h-full p-6 hover:border-[color:var(--color-teal)]/40 transition-colors"
          >
            <div class="flex items-center gap-3 text-xs font-mono uppercase tracking-[0.18em] text-[color:var(--color-text-muted)] mb-3">
              <span class="text-[color:var(--color-teal)]">{post.category}</span>
              <span>·</span>
              <FormattedDate date={post.date} />
            </div>
            <h2 class="text-lg font-semibold text-white leading-snug tracking-tight">
              {post.entry.data.title}
            </h2>
            {post.entry.data.excerpt && (
              <p class="mt-3 text-sm text-[color:var(--color-text-muted)] leading-relaxed line-clamp-3">
                {post.entry.data.excerpt}
              </p>
            )}
            <span class="mt-5 inline-flex items-center text-sm text-[color:var(--color-teal)]">
              Read →
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
