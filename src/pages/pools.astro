---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import FinalCTA from '../components/home/FinalCTA.astro';
import { POOLS_CONTENT } from '../data/pages.js';
---

<Layout title="Mining Pools" description="Pick a Salvium mining pool that matches your preferred payment system and fees.">
  <PageHero
    eyebrow="/ Mining Pools"
    title="Mining Pools"
    intro="Salvium uses the RandomX algorithm. Pick a pool that matches your preferred payment system and fee structure, then point your miner."
  />
  <section class="relative pb-16">
    <div class="max-w-6xl mx-auto px-5 lg:px-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {POOLS_CONTENT.map((p) => (
        <a href={p.href} target="_blank" rel="noopener noreferrer" class="group glass p-6 h-full flex flex-col hover:border-[color:var(--color-teal)]/40 transition-colors">
          <span class="w-10 h-10 rounded-lg bg-[color:var(--color-teal)]/10 border border-[color:var(--color-teal)]/30 flex items-center justify-center text-[color:var(--color-teal)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14 8 4-4 4 4-4 4-4-4z"/><path d="m18 12 2 2-9 9-2.5.5L9 21l9-9z"/><path d="m9 8 1 1"/><path d="m4 13 7 7"/></svg>
          </span>
          <h3 class="mt-5 font-display text-xl font-semibold">{p.name}</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] px-2 py-1 rounded border border-white/10 text-white/55">
                {t}
              </span>
            ))}
          </div>
          <span class="mt-auto pt-5 inline-flex items-center gap-2 text-sm text-white/70 group-hover:text-[color:var(--color-teal)] transition-colors">
            Visit pool ↗
          </span>
        </a>
      ))}
    </div>
  </section>

  <FinalCTA />
</Layout>
