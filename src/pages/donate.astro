---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import FinalCTA from '../components/home/FinalCTA.astro';

const ADDRESSES = [
  {
    label: 'Standard Donation Address',
    description: 'Use this for regular SAL donations.',
    address: 'SaLvdTpya4SEgMWDVQ9eDsgJJEwhB2pb5N4YZPMeVjg4BpwoigpKuTMS1TC92ziNyu5EvKaXLMy2LX8PXa1kNsRjBSYPTgyc3J5',
  },
  {
    label: 'Carrot Donation Address',
    description: 'Use this Carrot address if your wallet supports it.',
    address: 'SC11SxSj5yuT71WCWB1VsthazjnakytLLZrdpD3k7RKGVQEWH57w6zNbvhvP14dheJNiGwvwy3Fp915khxe1KMGuAea3anrm8a',
  },
];
---

<Layout title="Donate" description="Support Salvium development. Standard and Carrot donation addresses below.">
  <PageHero
    eyebrow="/ Donate"
    title="Support Salvium"
    intro="Your support funds development, audits, and community initiatives. Thank you."
  />
  <section class="relative pb-16">
    <div class="max-w-3xl mx-auto px-5 lg:px-8 space-y-5">
      {ADDRESSES.map((entry) => (
        <div class="glass p-6">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div>
              <h2 class="font-display text-xl md:text-2xl font-semibold text-white">{entry.label}</h2>
              <p class="mt-1 text-sm text-white/65">{entry.description}</p>
            </div>
            <button
              type="button"
              data-copy-address={entry.address}
              aria-label={`Copy ${entry.label}`}
              class="copy-btn shrink-0 inline-flex items-center gap-2 px-4 py-2.5 rounded-lg border border-white/15 bg-white/5 hover:bg-white/10 text-xs font-mono uppercase tracking-[0.18em] text-white/85 transition-colors min-h-[44px]"
            >
              <span class="copy-icon">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </span>
              <span class="copy-label">Copy</span>
            </button>
          </div>
          <div class="mt-4 rounded-lg border border-white/10 bg-black/30 p-4">
            <p class="font-mono text-sm md:text-base break-all text-white/90 leading-relaxed">
              {entry.address}
            </p>
          </div>
        </div>
      ))}
      <div class="rounded-2xl border border-yellow-500/25 bg-yellow-100/[0.04] p-5 flex items-start gap-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-200/85 shrink-0 mt-0.5" aria-hidden="true">
          <path fill-rule="evenodd" d="M10.29 3.86a2.25 2.25 0 013.42 0l7.42 9.11c1.24 1.52.13 3.78-1.71 3.78H4.58c-1.84 0-2.95-2.26-1.71-3.78l7.42-9.11zM12 8.25a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zm0 9a.9.9 0 100-1.8.9.9 0 000 1.8z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-yellow-100/85 leading-relaxed">
          Always verify the address before sending. On-chain transactions are irreversible —
          double-check every character matches what&rsquo;s shown above.
        </p>
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>

<!-- Copy-to-clipboard handler. Tiny vanilla JS so we don't ship a React
     island just for this — clipboard API + DOM swap is plenty. -->
<script>
  document.querySelectorAll('button[data-copy-address]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const addr = btn.getAttribute('data-copy-address');
      const label = btn.querySelector('.copy-label');
      try {
        await navigator.clipboard.writeText(addr);
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied';
          setTimeout(() => { label.textContent = original; }, 2000);
        }
      } catch (err) {
        console.error('[donate] clipboard write failed:', err);
      }
    });
  });
</script>
