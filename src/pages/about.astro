---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { ABOUT_CONTENT } from '../data/pages.js';

const dist = ABOUT_CONTENT.distribution;
---

<Layout title="About" description={ABOUT_CONTENT.intro.slice(0, 160)}>
  <PageHero eyebrow={ABOUT_CONTENT.eyebrow} title={ABOUT_CONTENT.title} intro={ABOUT_CONTENT.intro} />

  <section class="relative pb-16">
    <div class="max-w-4xl mx-auto px-5 lg:px-8 grid gap-5">
      {ABOUT_CONTENT.sections.map((s) => (
        <article class="glass p-6 md:p-8">
          <h2 class="font-display text-xl md:text-2xl font-semibold text-white">{s.title}</h2>
          <p class="mt-3 text-white/70 leading-relaxed">{s.body}</p>
        </article>
      ))}
    </div>
  </section>

  {dist && (
    <section class="relative pb-20">
      <div class="max-w-4xl mx-auto px-5 lg:px-8">
        <div class="font-mono text-[11px] uppercase tracking-[0.32em] text-[color:var(--color-teal)] mb-4">
          / Distribution
        </div>
        <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-tight text-white">
          {dist.title}
        </h2>
        {dist.intro && (
          <p class="mt-4 text-white/70 leading-relaxed max-w-3xl">{dist.intro}</p>
        )}
        <div class="mt-8 grid md:grid-cols-3 gap-5">
          {dist.items.map((d) => (
            <article class="glass p-6">
              <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-[color:var(--color-teal)]">
                {d.percent}
              </div>
              <h3 class="mt-3 font-display text-lg font-semibold text-white">{d.label}</h3>
              <p class="mt-3 text-sm text-white/65 leading-relaxed">{d.body}</p>
            </article>
          ))}
        </div>
        {dist.footnote && (
          <p class="mt-8 text-xs text-white/50 leading-relaxed">{dist.footnote}</p>
        )}
      </div>
    </section>
  )}
</Layout>
