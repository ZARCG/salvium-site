---
// /download surfaces the Products section as a standalone page so the nav
// link resolves to a real route. The home page also embeds <Products /> —
// it's the single source of truth for download UI so a future build-time
// release fetcher (replacing the React PR's runtime API call) lands once
// and updates both surfaces.
import Layout from '../layouts/Layout.astro';
import Products from '../components/home/Products.astro';
---

<Layout title="Download" description="Download the official Salvium GUI Wallet and CLI for Windows, macOS, and Linux.">
  <Products />
</Layout>
